{
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(/opt/homebrew/bin/plan today *)",
      "Bash(/opt/homebrew/bin/plan on *)",
      "Bash(/opt/homebrew/bin/plan next *)",
      "Bash(/opt/homebrew/bin/plan calendars *)",
      "Bash(/opt/homebrew/bin/plan hours *)",
      "Bash(/opt/homebrew/bin/reminders add *)",
      "Bash(/opt/homebrew/bin/reminders delete *)",
      "Bash(/opt/homebrew/bin/reminders edit *)",
      "Bash(/opt/homebrew/bin/reminders show *)",
      "Bash(/opt/homebrew/bin/reminders show-all *)",
      "Bash(/opt/homebrew/bin/reminders show-lists *)",
      "Bash(lightpanda fetch:*)",
      "Bash(nix search:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion|Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/timeout 1 /bin/sh -c 'sketchybar --trigger ai_agent_waiting SESSION_ID=$(tmux display-message -p \"#{session_id}\") WINDOW_ID=$(tmux display-message -p \"#{window_id}\")' || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "AskUserQuestion|Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/timeout 1 /bin/sh -c 'sketchybar --trigger ai_agent_done SESSION_ID=$(tmux display-message -p \"#{session_id}\") WINDOW_ID=$(tmux display-message -p \"#{window_id}\")' || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/timeout 1 /bin/sh -c 'sketchybar --trigger ai_agent_done SESSION_ID=$(tmux display-message -p \"#{session_id}\") WINDOW_ID=$(tmux display-message -p \"#{window_id}\")' || true"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "includePatterns": [
    "**/*"
  ],
  "theme": "dark",
  "verbose": false,
  "excludePatterns": [
    ".release/**",
    "build/**",
    "dist/**",
    "node_modules/**",
    "out-tsc/**"
  ]
}
