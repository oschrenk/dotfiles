#!/usr/bin/env lua

-- chezmoi-managed lua sources live in ~/.config/sketchybar/; Nix Home Manager
-- only provisions sbarlua + lua-tz on package.path, so we extend it to find
-- icons, style, items/, services/, utils/...
package.path = package.path .. ";/Users/" .. os.getenv("USER") .. "/.config/sketchybar/?.lua"

-- dependencies
local sbar = require("sketchybar")

-- settings
local icons = require("icons")
local style = require("style")

-- services
local focus = require("services.focus").new()
local mission = require("services.mission").new()
local sessionizer = require("services.sessionizer").new()

-- bundle configuration into single message
sbar.begin_config()
sbar.hotload(true)

sbar.bar(style.bar)
sbar.default(style.default)

-- left
require("items.sessions").new(icons.sessions, style.sessions).add("left")
require("items.windows").new(icons.windows, style.windows).add("left")
require("items.mission").new(mission, focus, icons.mission).add("left")
require("items.project").new(icons.project, sessionizer).add("left")

-- center (manually arround the dynamic island)
-- local clockWidth = 100
-- local dynamicIslandWidth = 184
-- require("items.meter").new(meter, 100).add("center")
-- require("items.spacer").new(dynamicIslandWidth).add("center")
-- require("items.comodoro").new(comodoro, style.pomodoro).add("center", clockWidth)

-- right
require("items.clock").new(icons.clock).add("right")
require("items.battery").new().add("right")
require("items.calendar").new(icons.calendar, focus).add("right")

sbar.end_config()

sbar.event_loop()
