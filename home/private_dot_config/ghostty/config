# vim: filetype=ruby

# Reference
#   see also https://ghostty.org/docs/config/reference
#
# Docs
#   `ghostty +show-config --default --docs | nvim`
#
# Resources:
#   https://github.com/search?q=path%3Aghostty%2Fconfig&type=code



# Window behaviour
#   don't confirm closing/quitting
confirm-close-surface = false
quit-after-last-window-closed = true

# Window Decoration
#   https://ghostty.org/docs/config/reference#window-decoration
# round-corners in macOS
window-decoration = auto
# hide buttons and tabs
macos-titlebar-style = hidden
window-padding-x = 20
window-padding-y = 4
initial-window = true
# hide "shadow"
macos-window-shadow = false

# Font Configuration
#   to list valid fonts `ghostty +list-fonts`
font-size = 22
font-family = "JetBrainsMono Nerd Font Mono"
font-style = "ExtraLight"
font-style-bold = "Regular"
font-style-italic = "ExtraLight Italic"
font-style-bold-italic = "Regular Italic"
font-thicken = true

# Cursor
#   https://ghostty.org/docs/config/reference#cursor-style
cursor-style = block

# Shell
#   https://ghostty.org/docs/config/reference#initial-command
#   https://ghostty.org/docs/config/reference#shell-integration
shell-integration = fish
command = /opt/homebrew/bin/fish --login --interactive
initial-command = /opt/homebrew/bin/fish --login --interactive --init-command "/opt/homebrew/bin/sessionizer start; tmux attach -t config"

# Appearance
#   https://ghostty.org/docs/config/reference#mouse-hide-while-typing
# to list valid themes:
#   ghostty +list-themes
theme = "Gruvbox Dark"
mouse-hide-while-typing = true

# Clipboard
clipboard-read = allow
clipboard-write = allow
clipboard-trim-trailing-spaces = true

# Quick Terminal
quick-terminal-animation-duration = 0
quick-terminal-autohide = true
quick-terminal-position = center
quick-terminal-screen = mouse
quick-terminal-size = "50%,50%"

##########################
# SPLITS
##########################
split-divider-color=e7dbb6
unfocused-split-fill=e7dbb6
unfocused-split-opacity=0.95

##########################
# KEYBOARD
##########################
# https://ghostty.org/docs/config/reference#macos-option-as-alt
macos-option-as-alt = true

# Keybindings
#   https://ghostty.org/docs/config/reference#keybind
#   ghostty +list-keybinds
#   [alt|ctrl|shift|super] + key
# dont' create new windows
keybind = super+n=unbind
# dont' create new tabs
keybind = super+t=unbind
# move splits
keybind = super+h=goto_split:left
keybind = super+i=goto_split:up
keybind = super+j=goto_split:down
keybind = super+l=goto_split:right
keybind = super+up=resize_split:up,10
keybind = super+down=resize_split:down,10
keybind = super+left=resize_split:left,10
keybind = super+right=resize_split:right,10
keybind = super+s=activate_key_table:splits
keybind = splits/-=new_split:down
keybind = chain=goto_split:down
keybind = chain=deactivate_key_table
keybind = splits/shift+\=new_split:right
keybind = chain=goto_split:right
keybind = chain=deactivate_key_table
keybind = splits/shift+\=new_split:right

# reload config
keybind = super+r=reload_config

# open quick terminal
keybind = global:super+grave_accent=toggle_quick_terminal
