{{- $name := promptStringOnce . "name" "Full name" -}}

{{- $personal_email := promptStringOnce . "personal.email" "Personal email address" -}}

{{- $personal_google_oauth_client_id := promptStringOnce . "personal.google_oauth_client_id" "Personal Google OAuth Client ID" -}}

{{- $work_email := promptStringOnce . "work.email" "Work email address" -}}

{{- $tags := list -}}
{{- if eq .chezmoi.hostname "Olivers-MaxBook" -}}
{{-   $tags = list "gui" "work" "thicc" "server" -}}
{{- else if eq .chezmoi.hostname "Olivers-MacBook-Air" -}}
{{-   $tags = list "gui" "work" -}}
{{- else if eq .chezmoi.hostname "Olivers-Mac-mini" -}}
{{-   $tags = list -}}
{{- end -}}

[diff]
  pager = "delta"

[data]
  name = {{ $name | quote }}
  tags = {{ $tags | toJson }}

[data.personal]
  email = {{ $personal_email | quote }}
  google_oauth_client_id = {{ $personal_google_oauth_client_id | quote }}

[data.work]
  email = {{ $work_email | quote }}
